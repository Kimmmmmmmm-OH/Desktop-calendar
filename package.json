{
  "name": "desktop-calendar",
  "version": "4.2.0",
  "description": "桌面日历清单 - Desktop Calendar & Todo List",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.desktopcalendar.app",
    "productName": "桌面日历清单",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
